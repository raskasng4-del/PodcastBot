# @title 4️⃣ ▶️ تشغيل البوت
import yt_dlp
import requests
from moviepy.editor import *
import arabic_reshaper
from bidi.algorithm import get_display

OUTPUT = "/content/drive/MyDrive/Podcast_Abdo_Samir"
os.makedirs(OUTPUT, exist_ok=True)

def process(url, i, bg_path):
    print(f"\n{'='*40}\n🎬 الحلقة ({i})\n{'='*40}")
    
    # تحميل الصوت
    ydl = yt_dlp.YoutubeDL({
        'format': 'bestaudio/best',
        'outtmpl': f'/content/raw_{i}.%(ext)s',
        'postprocessors': [{'key': 'FFmpegExtractAudio', 'preferredcodec': 'mp3'}],
        'quiet': True,
    })
    ydl.extract_info(url, download=True)
    
    if not os.path.exists(f'/content/raw_{i}.mp3'):
        print(f"❌ فشل التحميل")
        return
    
    # تحسين الصوت
    subprocess.run(['ffmpeg', '-i', f'/content/raw_{i}.mp3',
                    '-af', 'volume=1.5,atempo=1.02', '-y',
                    f'/content/enhanced_{i}.mp3'], capture_output=True)
    
    audio = AudioFileClip(f'/content/enhanced_{i}.mp3')
    dur = audio.duration
    print(f"⏱️ المدة: {dur:.1f} ثانية")
    
    # فيديو
    bg = ImageClip(bg_path).set_duration(dur)
    bg = bg.resize(lambda t: 1 + 0.03 * t / dur)
    
    text = get_display(arabic_reshaper.reshape(f"{STORY_TITLE} | الحلقة ({i})"))
    txt = TextClip(text, fontsize=45, color='white',
                   font='/content/Cairo-Bold.ttf',
                   bg_color='rgba(0,0,0,0.6)',
                   method='caption', size=(bg.w*0.8, None))
    txt = txt.set_duration(dur).set_position(('center', 'center'))
    
    video = CompositeVideoClip([bg, txt]).set_audio(audio)
    out = f"{OUTPUT}/Abdo_Samir_Pro_{i}.mp4"
    video.write_videofile(out, fps=24, codec="libx264", audio_codec="aac",
                          preset="medium", verbose=False, logger=None)
    audio.close(); video.close()
    
    # تنظيف
    for f in [f'/content/raw_{i}.mp3', f'/content/enhanced_{i}.mp3']:
        try: os.remove(f)
        except: pass
    
    print(f"✅ الحلقة {i}: {os.path.basename(out)} ({os.path.getsize(out)/1024/1024:.1f} MB)")
    
    # رفع
    print("📤 جاري الرفع...")
    with open(out, 'rb') as f:
        r = requests.post(
            f"https://graph-video.facebook.com/v18.0/{PAGE_ID}/videos",
            data={'description': f"{DESCRIPTION}\n\nالحلقة ({i})",
                  'access_token': ACCESS_TOKEN, 'published': 'true'},
            files={'source': (f'video_{i}.mp4', f, 'video/mp4')},
            timeout=600
        )
        res = r.json()
        if "id" in res:
            print(f"✅ منشورة! ID: {res['id']}")
        else:
            print(f"❌ {res}")

# تشغيل
for i, url in enumerate(URLS, 1):
    process(url, i, bg)

print(f"\n✅ انتهى! الملفات في: {OUTPUT}")
